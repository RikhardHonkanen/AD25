{
  "version": 7,
  "cmakeMinimumRequired": {
    "major": 3
  },
  "configurePresets": [
    {
      "name": "debug-env",
      "displayName": "debug-env",
      "hidden": true,
      "environment": {
        "MCUX_VENV_PATH": "${env:HOME}/.mcuxpressotools/.venv_3_12/bin",
        "PATH": "$env{MCUX_VENV_PATH}${pathListSep}$penv{PATH}",
        "ZEPHYR_BASE": "${env:HOME}/zephyr/zephyr",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "cacheVariables": {}
    },
    {
      "name": "release-env",
      "displayName": "release-env",
      "hidden": true,
      "environment": {
        "MCUX_VENV_PATH": "${env:HOME}/.mcuxpressotools/.venv_3_12/bin",
        "PATH": "$env{MCUX_VENV_PATH}${pathListSep}$penv{PATH}",
        "ZEPHYR_BASE": "${env:HOME}/zephyr/zephyr",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "cacheVariables": {}
    }
  ],
  "buildPresets": []
}